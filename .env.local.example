NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxx

# 자동 동기화(Cron)용 - 로그인 세션 없이 서버에서 DB 쓰기 위한 관리자 키
# Supabase 대시보드 -> Project Settings -> API -> service_role 키 (secret) 복사
SUPABASE_SERVICE_ROLE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxx

# 외부 무료 스케줄러(cron-job.org 등)로 더 자주 동기화하고 싶을 때 쓰는 비밀값
# 아무 문자열이나 직접 정해서 넣으면 됨 (예: 랜덤 문자열 생성기로 만든 값)
COUPANG_SYNC_SECRET=여기에_직접_정한_비밀값
